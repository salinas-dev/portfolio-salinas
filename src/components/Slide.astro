---
const {
  tone = "paper",     // "sage" | "sand" | "paper"
  grid = true,
  align = "left",     // "left" | "center"
} = Astro.props;

const toneClass = tone === "sage" ? "bg-sage" : tone === "sand" ? "bg-sand" : "bg-paper";
const gridClass = grid ? "gridlines" : "";
const alignStyle = align === "center" ? "text-align:center; display:grid; place-items:center;" : "";
---
<section class={`card slide ${toneClass} ${gridClass}`} style={alignStyle}>
  <slot />
</section>