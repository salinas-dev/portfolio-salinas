---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import { site } from "../data/site";

const projects = await getCollection("projects");
const featuredProjects = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 4);
---

<BaseLayout title={`${site.name} — Portfolio`} description={site.description}>
  <Navbar />

  <main>
    <section class="hero section">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">WEB DESIGN · UI/UX · FRONTEND</p>
          <h1>
            Diseño experiencias web
            <br />
            limpias, editoriales
            <br />
            y funcionales.
          </h1>
          <p class="lead">
            Portafolio enfocado en diseño web, interfaces UI/UX y desarrollo
            frontend con estética minimalista y atención al detalle.
          </p>

          <div class="hero-actions">
            <a href="/projects" class="btn btn-dark">Ver proyectos</a>
            <a href="/about" class="btn btn-light">Sobre mí</a>
            <a href="/cv.pdf" target="_blank" class="btn btn-light"
              >Descargar CV</a
            >
          </div>
        </div>

        <div class="hero-card">
          <div class="hero-card-inner">
            <div class="hero-photo-wrap">
              <img
                src="/images/nora.jpeg"
                alt="Foto de Nora Salinas"
                class="hero-photo"
              />
            </div>

            <p class="eyebrow">ABOUT ME</p>
            <h2>Nora Salinas</h2>
            <p>
              Diseñadora y desarrolladora web enfocada en interfaces elegantes,
              experiencia de usuario y sitios visualmente sólidos.
            </p>

            <div class="mini-links">
              <a href={`mailto:${site.email}`}>Email</a>
              <a href={site.github} target="_blank">GitHub</a>
              <a href="/contact">Contacto</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-soft">
      <div class="container split-intro">
        <div>
          <p class="eyebrow">SELECTED WORK</p>
          <h2>Proyectos destacados</h2>
        </div>

        <div>
          <p class="section-text">
            Una selección de proyectos de diseño y desarrollo web centrados en
            claridad visual, jerarquía tipográfica, composición y experiencia de
            usuario.
          </p>
        </div>
      </div>

      <div class="container projects-grid">
        {
          featuredProjects.map((project) => (
            <a href={`/projects/${project.slug}`} class="project-card">
              <div class="project-image-wrap">
                <img
                  src={project.data.cover}
                  alt={project.data.title}
                  class="project-image"
                />
              </div>

              <div class="project-meta">
                <p class="project-category">{project.data.category}</p>
                <h3>{project.data.title}</h3>
                <p>{project.data.description}</p>
                <span class="project-year">{project.data.year}</span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="container two-column-info">
        <div class="info-block block-beige">
          <p class="eyebrow">SERVICES</p>
          <h2>Diseño web & UI/UX</h2>
          <p>
            Diseño de interfaces, landing pages, portfolios, sistemas visuales y
            experiencias web orientadas a claridad, estética y usabilidad.
          </p>
        </div>

        <div class="info-block block-light">
          <p class="eyebrow">TOOLS</p>
          <h2>Herramientas</h2>
          <p>
            Figma · HTML · CSS · JavaScript · React · Astro · Tailwind · Git
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container cta-panel">
        <p class="eyebrow">AVAILABLE FOR WORK</p>
        <h2>Disponible para proyectos web, UI y diseño digital</h2>
        <p>
          Abierta a colaborar en portfolios, landing pages, interfaces modernas
          y sitios con enfoque visual fuerte.
        </p>

        <div class="hero-actions">
          <a href="/projects" class="btn btn-dark">Proyectos</a>
          <a href="/contact" class="btn btn-light">Contacto</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
