---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={`${project.data.title} — Portfolio`}
  description={project.data.description}
>
  <Navbar />

  <main class="section">
    <div class="container project-detail project-detail-clean">
      <div class="project-header">
        <div class="project-header-top">
          <p class="eyebrow">{project.data.category}</p>

          {
            project.data.figma && (
              <a
                href={project.data.figma}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-light project-figma-btn"
              >
                Ver Figma
              </a>
            )
          }
        </div>

        <h1 class="page-title">{project.data.title}</h1>
        <p class="project-lead">{project.data.description}</p>
      </div>
      <div class="project-actions">
        {
          project.data.demo && (
            <a
              href={project.data.demo}
              target="_blank"
              rel="noopener"
              class="btn btn-dark"
            >
              Ver demo
            </a>
          )
        }

        {
          project.data.repo && (
            <a
              href={project.data.repo}
              target="_blank"
              rel="noopener"
              class="btn btn-light"
            >
              Ver repositorio
            </a>
          )
        }
      </div>

      <div class="project-hero-media">
        <img
          src={project.data.cover}
          alt={project.data.title}
          class="project-detail-image"
        />
      </div>

      <div class="project-info-grid project-info-grid-clean">
        <div class="project-info-card">
          <span>Año</span>
          <p>{project.data.year}</p>
        </div>

        <div class="project-info-card">
          <span>Herramientas</span>
          <p>{project.data.tools.join(" · ")}</p>
        </div>
      </div>

      {
        project.data.highlights?.length > 0 && (
          <section class="project-highlights">
            <span>Highlights</span>
            <ul>
              {project.data.highlights.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </section>
        )
      }

      <article class="project-content">
        <Content />
      </article>
    </div>
  </main>

  <Footer />
</BaseLayout>
