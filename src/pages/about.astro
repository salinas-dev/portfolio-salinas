---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
---

<BaseLayout title={`About — ${site.name}`} description="Sobre mí">
  <Navbar />

  <main class="section">
    <div class="container about-grid">
      <div class="about-left">
        <p class="eyebrow">ABOUT</p>
        <h1 class="page-title">Sobre mí</h1>

        <div class="about-visual">
          <div class="about-main-photo">
            <img
              src="/images/nora.png"
              alt="Foto de Nora Salinas"
              class="about-photo"
            />
          </div>

          <div class="about-floating about-img-1">
            <img src="/images/mood-01.png" alt="Inspiración visual 1" />
          </div>

          <div class="about-floating about-img-2">
            <img src="/images/mood-02.png" alt="Inspiración visual 2" />
          </div>

          <div class="about-floating about-img-3">
            <img src="/images/mood-03.png" alt="Inspiración visual 3" />
          </div>

          <span class="about-badge badge-star">✦</span>
          <span class="about-badge badge-heart">♡</span>
        </div>
      </div>

      <div class="page-copy about-right">
        <p class="about-short">
          Diseñadora y desarrolladora web enfocada en interfaces limpias,
          experiencia de usuario y diseño visual.
        </p>

        <p>
          Soy una profesional interesada en el diseño web, la experiencia de
          usuario y el desarrollo frontend con enfoque visual.
        </p>

        <p>
          Me atraen los sitios editoriales, limpios y bien estructurados, donde
          la composición, la tipografía y la jerarquía de contenido realmente
          aportan valor.
        </p>

        <p>
          Mi objetivo es construir interfaces funcionales y elegantes, que no
          solo se vean bien, sino que comuniquen con claridad.
        </p>

        <div class="info-list about-info">
          <div>
            <span>Enfoque</span>
            <p>Web Design · UI/UX · Frontend</p>
          </div>

          <div>
            <span>Herramientas</span>
            <p>Figma · Astro · React · CSS · JS</p>
          </div>

          <div>
            <span>Ubicación</span>
            <p>México</p>
          </div>
        </div>

        <div class="about-tags">
          <span>✦ Creatividad visual</span>
          <span>♡ Diseño limpio</span>
          <span>☁ Experiencia de usuario</span>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
